 xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><msup><mfenced><mrow><mi>f</mi><mfenced><mi>t</mi></mfenced></mrow></mfenced><mn>2</mn></msup><mo>+</mo><msup><mfenced><mrow><mi>g</mi><mfenced><mi>t</mi></mfenced></mrow></mfenced><mn>2</mn></msup></math>&nbsp;&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;<em><strong>AG</strong></em></p>\n<p><em><strong><br></strong></em><strong>Note: </strong>Accept combinations of METHODS 1 &amp; 2 that meet at equivalent expressions.</p>\n<p><em><strong><br></strong></em><em><strong>[3 marks]</strong></em></p>","meta":{"questionId":"22561","referenceCode":"21N.3.AHL.TZ0.1b","subjectId":"50-dp-mathematics-analysis-and-approaches","title":"Show that ft2+gt2=f2t.","paper":"3","level":"HL","questionNumber":"b","marksAvailable":"[Maximum mark: 3]","breadcrumbLabels":["Topic 1—Number and algebra","Topic 2—Functions","Topic 5 —Calculus","Topic 5 —Calculus","SL 5.6—Differentiating polynomials n E Q. Chain, product and quotient rules","Topic 5 —Calculus","SL 5.7—The second derivative","Topic 2—Functions","SL 2.3—Graphing","Topic 1—Number and algebra","SL 1.6—Simple proof","Topic 1—Number and algebra","AHL 1.12—Complex numbers – Cartesian form and Argand diag","Topic 1—Number and algebra","AHL 1.13—Polar and Euler form"],"memberSectionIds":[],"sectionOrders":{}},"schemaVersion":2}