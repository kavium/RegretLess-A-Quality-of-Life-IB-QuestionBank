:"25652","referenceCode":"22M.1.AHL.TZ1.12c.i","subjectId":"50-dp-mathematics-analysis-and-approaches","title":"Show that g(x) satisfies the equation g''(x)=2(g'(x)-g(x)).","paper":"1","level":"AHL","questionNumber":"c.i","marksAvailable":"[Maximum mark: 4]","breadcrumbLabels":["Topic 5 —Calculus","Topic 5 —Calculus","SL 5.7—The second derivative"],"memberSectionIds":[],"sectionOrders":{}}}