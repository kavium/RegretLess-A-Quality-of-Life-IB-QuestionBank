bsp; &nbsp; &nbsp; &nbsp; &nbsp;<em><strong>&nbsp;AG</strong></em></p>\n<p>&nbsp;</p>\n<p><em><strong>[2 marks]</strong></em></p>","meta":{"questionId":"20264","referenceCode":"21M.1.SL.TZ1.6a","subjectId":"50-dp-mathematics-analysis-and-approaches","title":"Show that sin 2x+cos 2x-1=2 sin xcos x-sin x.","paper":"1","level":"SL","questionNumber":"a","marksAvailable":"[Maximum mark: 2]","breadcrumbLabels":["Topic 3— Geometry and trigonometry","Topic 3— Geometry and trigonometry","SL 3.6—Pythagorean identity, double angles","Topic 3— Geometry and trigonometry","SL 3.8—Solving trig equations"],"memberSectionIds":[],"sectionOrders":{}}}