mi></mrow></mfrac></mrow></mfenced></math><em> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; (A1)</em></strong></p>\n<p><strong><em><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>z</mi><mo>=</mo><mn>3</mn><mo>+</mo><mi mathvariant=\"normal\">i</mi></math> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; A1</em></strong></p>\n<p><strong><em><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfenced><mrow><mi>a</mi><mo>=</mo><mn>3</mn><mo>,</mo><mo>&nbsp;</mo><mi>b</mi><mo>=</mo><mn>1</mn></mrow></mfenced></math></em></strong></p>\n<p style=\"text-align:right;\"><strong><em>[4 marks]</em></strong></p>","meta":{"questionId":"33299112","referenceCode":"24N.2.AHL.TZ0.8b","subjectId":"50-dp-mathematics-analysis-and-approaches","title":"Given that |w|=25, find z expressing your answer in the form a+bi, where a, b∈ℤ.","paper":"2","level":"AHL","questionNumber":"b","marksAvailable":"[Maximum mark: 4]","breadcrumbLabels":["Topic 1—Number and algebra","Topic 1—Number and algebra","AHL 1.12—Complex numbers – Cartesian form and Argand diag"],"memberSectionIds":[],"sectionOrders":{}}}