     </mrow>\n      <mi>u</mi>\n    </msup>\n  </mrow>\n  <mo>−</mo>\n  <mn>2</mn>\n  <mi>u</mi>\n  <mrow>\n    <msup>\n      <mrow>\n        <mtext>e</mtext>\n      </mrow>\n      <mi>u</mi>\n    </msup>\n  </mrow>\n  <mo>+</mo>\n  <mo>∫</mo>\n  <mrow>\n    <mn>2</mn>\n    <mrow>\n      <msup>\n        <mrow>\n          <mtext>e</mtext>\n        </mrow>\n        <mi>u</mi>\n      </msup>\n    </mrow>\n  </mrow>\n  <mrow>\n    <mtext>d</mtext>\n  </mrow>\n  <mi>u</mi>\n</math></span>&nbsp; &nbsp; &nbsp;&nbsp;<em><strong>A1</strong></em></p>\n<p><span class=\"mjpage\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\" alttext=\" = {u^2}{{\\text{e}}^u} - 2u{{\\text{e}}^u} + 2{{\\text{e}}^u} + c\">\n  <mo>=</mo>\n  <mrow>\n    <msup>\n      <mi>u</mi>\n      <mn>2</mn>\n    </msup>\n  </mrow>\n  <mrow>\n    <msup>\n      <mrow>\n        <mtext>e</mtext>\n      </mrow>\n      <mi>u</mi>\n    </msup>\n  </mrow>\n  <mo>−</mo>\n  <mn>2</mn>\n  <mi>u</mi>\n  <mrow>\n    <msup>\n      <mrow>\n        <mtext>e</mtext>\n      </mrow>\n      <mi>u</mi>\n    </msup>\n  </mrow>\n  <mo>+</mo>\n  <mn>2</mn>\n  <mrow>\n    <msup>\n      <mrow>\n        <mtext>e</mtext>\n      </mrow>\n      <mi>u</mi>\n    </msup>\n  </mrow>\n  <mo>+</mo>\n  <mi>c</mi>\n</math></span></p>\n<p><span class=\"mjpage\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\" alttext=\"&nbsp;= x{\\left( {{\\text{ln}}\\,x} \\right)^2} - 2x\\,{\\text{ln}}\\,x + 2x + c\">\n  <mo>=</mo>\n  <mi>x</mi>\n  <mrow>\n    <msup>\n      <mrow>\n        <mo>(</mo>\n        <mrow>\n          <mrow>\n            <mtext>ln</mtext>\n          </mrow>\n          <mspace width=\"thinmathspace\"></mspace>\n          <mi>x</mi>\n        </mrow>\n        <mo>)</mo>\n      </mrow>\n      <mn>2</mn>\n    </msup>\n  </mrow>\n  <mo>−</mo>\n  <mn>2</mn>\n  <mi>x</mi>\n  <mspace width=\"thinmathspace\"></mspace>\n  <mrow>\n    <mtext>ln</mtext>\n  </mrow>\n  <mspace width=\"thinmathspace\"></mspace>\n  <mi>x</mi>\n  <mo>+</mo>\n  <mn>2</