le scriptlevel=\"0\" displaystyle=\"false\"> <mfrac> <mn>6</mn> <mn>8</mn> </mfrac> </mstyle> </mrow> </mtd> </mtr> </mtable> </mrow> <mo>)</mo> </mrow> <mrow> <mtext>,</mtext> </mrow> <mspace width=\"thinmathspace\"></mspace> <mspace width=\"thinmathspace\"></mspace> <mspace width=\"thinmathspace\"></mspace> <mrow> <msub> <mrow> <mrow> <mi mathvariant=\"bold\">v</mi> </mrow> </mrow> <mn>4</mn> </msub> </mrow> <mo>=</mo> <mrow> <mo>(</mo> <mrow> <mtable columnspacing=\"1em\" rowspacing=\"4pt\"> <mtr> <mtd> <mn>0</mn> </mtd> </mtr> <mtr> <mtd> <mrow> <mstyle scriptlevel=\"0\" displaystyle=\"false\"> <mfrac> <mn>1</mn> <mrow> <mn>16</mn> </mrow> </mfrac> </mstyle> </mrow> </mtd> </mtr> <mtr> <mtd> <mrow> <mstyle scriptlevel=\"0\" displaystyle=\"false\"> <mfrac> <mn>1</mn> <mrow> <mn>16</mn> </mrow> </mfrac> </mstyle> </mrow> </mtd> </mtr> <mtr> <mtd> <mrow> <mstyle scriptlevel=\"0\" displaystyle=\"false\"> <mfrac> <mrow> <mn>14</mn> </mrow> <mrow> <mn>16</mn> </mrow> </mfrac> </mstyle> </mrow> </mtd> </mtr> </mtable> </mrow> <mo>)</mo> </mrow> <mspace width=\"thinmathspace\"></mspace> </math></span>&nbsp;&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;<em><strong>A1A1A1A1</strong></em></p>\n<p><em><strong>[4 marks]</strong></em></p>","meta":{"questionId":"11858","referenceCode":"EXM.3.AHL.TZ0.4e","subjectId":"51-dp-mathematics-applications-and-interpretation","title":"Find v 1 , v 2 , v 3 , v 4 .","paper":"3","level":"HL","questionNumber":"e","marksAvailable":"[Maximum mark: 4]","breadcrumbLabels":["Topic 4—Statistics and probability","Topic 4—Statistics and probability","AHL 4.19—Transition matrices – Markov chains"],"memberSectionIds":[],"sectionOrders":{}},"schemaVersion":2}