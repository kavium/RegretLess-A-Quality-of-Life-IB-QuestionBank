enced><mrow><msub><mi>z</mi><mn>1</mn></msub><mo>&nbsp;</mo><mo>+</mo><mo>&nbsp;</mo><msub><mi>z</mi><mn>2</mn></msub></mrow></mfenced><mo>&nbsp;</mo><mo>=</mo><mo>&nbsp;</mo><mn>2</mn><mo>.</mo><mn>91</mn><mo> </mo><mi>sin</mi><mo> </mo><mfenced><mrow><mn>2</mn><mi>t</mi><mo>&nbsp;</mo><mo>-</mo><mo>&nbsp;</mo><mn>0</mn><mo>.</mo><mn>351</mn></mrow></mfenced></math>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;&nbsp;<strong><em>A1</em></strong></p>\n<p style=\"text-align:right;\"><strong><em>[4 marks]</em></strong></p>","meta":{"questionId":"13421008","referenceCode":"23N.1.AHL.TZ0.8b","subjectId":"51-dp-mathematics-applications-and-interpretation","title":"Find Im z1 + z2 in the form p sin 2t + q, where p>0, t∈ℝ and -π≤q≤π.","paper":"1","level":"AHL","questionNumber":"b","marksAvailable":"[Maximum mark: 4]","breadcrumbLabels":["Topic 1—Number and algebra","Topic 1—Number and algebra","AHL 1.12—Complex numbers introduction","Topic 1—Number and algebra","AHL 1.13—Polar and Euler form"],"memberSectionIds":[],"sectionOrders":{}}}