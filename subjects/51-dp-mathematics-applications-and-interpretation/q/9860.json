  1&amp;1 \\\\   { - 1}&amp;2  \\end{array}} \\right)\">\n  <mrow>\n    <mo>(</mo>\n    <mrow>\n      <mtable rowspacing=\"4pt\" columnspacing=\"1em\">\n        <mtr>\n          <mtd>\n            <mn>1</mn>\n          </mtd>\n          <mtd>\n            <mn>1</mn>\n          </mtd>\n        </mtr>\n        <mtr>\n          <mtd>\n            <mrow>\n              <mo>−</mo>\n              <mn>1</mn>\n            </mrow>\n          </mtd>\n          <mtd>\n            <mn>2</mn>\n          </mtd>\n        </mtr>\n      </mtable>\n    </mrow>\n    <mo>)</mo>\n  </mrow>\n</math></span>&nbsp;&nbsp;<em><strong>D</strong></em>&nbsp;= <span class=\"mjpage\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\" alttext=\"\\left( {\\begin{array}{*{20}{c}}  {0.7}&amp;0 \\\\   0&amp;1  \\end{array}} \\right)\">\n  <mrow>\n    <mo>(</mo>\n    <mrow>\n      <mtable rowspacing=\"4pt\" columnspacing=\"1em\">\n        <mtr>\n          <mtd>\n            <mrow>\n              <mn>0.7</mn>\n            </mrow>\n          </mtd>\n          <mtd>\n            <mn>0</mn>\n          </mtd>\n        </mtr>\n        <mtr>\n          <mtd>\n            <mn>0</mn>\n          </mtd>\n          <mtd>\n            <mn>1</mn>\n          </mtd>\n        </mtr>\n      </mtable>\n    </mrow>\n    <mo>)</mo>\n  </mrow>\n</math></span>&nbsp;&nbsp; &nbsp; &nbsp;<em><strong>A1A1</strong></em></p>\n<p><em><strong>[2 marks]</strong></em></p>","meta":{"questionId":"9860","referenceCode":"SPM.2.AHL.TZ0.6c","subjectId":"51-dp-mathematics-applications-and-interpretation","title":"Hence write down matrices P and D such that T = PDP−1.","paper":"2","level":"AHL","questionNumber":"c","marksAvailable":"[Maximum mark: 2]","breadcrumbLabels":["Topic 4—Statistics and probability","Topic 4—Statistics and probability","AHL 4.19—Transition matrices – Markov chains"],"memberSectionIds":[],"sectionOrders":{}}}