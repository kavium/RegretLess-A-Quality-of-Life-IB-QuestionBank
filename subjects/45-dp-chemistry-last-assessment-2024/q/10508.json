{"questionId":"10508","questionHtml":"<div class=\"qb-parent-stem\"><p><span style=\"background-color:#ffffff;\">Rhenium, Re, was the last element with a stable isotope to be isolated.</span></p></div>\n<div class=\"qb-parent-stem\"><p><span style=\"background-color:#ffffff;\">One chloride of rhenium has the empirical formula ReCl<sub>3</sub>.</span></p></div>\n<div class=\"qb-leaf-prompt\"><p><span style=\"background-color:#ffffff;\">State the name of this compound, applying IUPAC rules.</span></p></div>","markschemeHtml":"<p><span style=\"background-color:#ffffff;\">rhenium(III) chloride<br><em><strong>OR</strong></em><br>rhenium trichloride &nbsp;&nbsp; <strong>[✔]</strong></span></p>","meta":{"questionId":"10508","referenceCode":"19M.2.hl.TZ2.4d(i)","subjectId":"45-dp-chemistry-last-assessment-2024","title":"State the name of this compound, applying IUPAC rules.","paper":"2","level":"HL","questionNumber":"d(i)","marksAvailable":"[Maximum mark: 1]","breadcrumbLabels":["Core","Core","Topic 9: Redox processes","9.1 Oxidation and reduction","Core","Topic 9: Redox processes"],"memberSectionIds":[],"sectionOrders":{}},"schemaVersion":2}