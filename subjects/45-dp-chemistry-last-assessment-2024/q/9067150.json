{"questionId":"9067150","questionHtml":"<div class=\"qb-parent-stem\"><p><span style=\"background-color:#ffffff;\">Uranium-235, <sup>235</sup>U, is bombarded with a neutron causing a fission reaction.</span></p></div>\n<div class=\"qb-parent-stem\"><p><span style=\"background-color:#ffffff;\">Two products of the fission of <sup>235</sup>U are <sup>144</sup>Ba and <sup>89</sup>Kr.</span></p></div>\n<div class=\"qb-leaf-prompt\"><p><span style=\"background-color:#ffffff;\">Write the nuclear equation for this fission reaction.</span></p></div>","markschemeHtml":"<p><span style=\"background-color:#ffffff;\"><sup>235</sup>U + <sup>1</sup>n → <sup>144</sup>Ba + <sup>89</sup>Kr + 3 <sup>1</sup>n&nbsp; <strong>[✔]</strong></span></p>","meta":{"questionId":"9067150","referenceCode":"19M.3.sl.TZ1.a(i)","subjectId":"45-dp-chemistry-last-assessment-2024","title":"Write the nuclear equation for this fission reaction.","paper":"3","level":"SL","questionNumber":"a(i)","marksAvailable":"[Maximum mark: 1]","breadcrumbLabels":["Options","Options","C: Energy","C.3 Nuclear fusion and fission","Options","C: Energy"],"memberSectionIds":[],"sectionOrders":{}},"schemaVersion":2}